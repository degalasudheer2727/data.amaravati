{
  "name": "data-amaravati",
  "version": "1.0.0",
  "private": true,
  "description": "data.amaravati — concept governed data platform & digital twin for Amaravati. Access open, internal, sensitive and confidential city data by authority. 3D website + Flutter hybrid app.",
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 5173 --directory web",
    "lint": "htmlhint \"web/**/*.html\"",
    "validate": "node -e \"['vercel.json','web/manifest.webmanifest'].forEach(f=>JSON.parse(require('fs').readFileSync(f,'utf8')))\" && echo ok",
    "sbom": "cdxgen -o sbom.json .",
    "preview": "vercel deploy",
    "deploy": "vercel deploy --prod"
  },
  "keywords": [
    "amaravati",
    "data-platform",
    "governed-data",
    "digital-twin",
    "threejs",
    "flutter",
    "vercel",
    "devsecops"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "htmlhint": "^1.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "motion": "^12.40.0"
  }
}
